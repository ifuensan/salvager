# hardware-hunter — environment variables.
#
# Copy this file to .env (next to wishlist.yaml / config.yaml in config_dir)
# and fill in your real values. Never commit the resulting .env — it is
# gitignored at the repo root for safety.
#
# All credentials are loaded ONCE at daemon start (FR49 — no hot-reload).
# Rotation requires `docker-compose restart`. The daemon enforces mode 0600
# on this file at startup and refuses to start otherwise (NFR-S2 / AR22).

# ─────────────────────────────────────────────────────────────────────────
# Telegram
# ─────────────────────────────────────────────────────────────────────────

# Bot token — create via @BotFather (https://t.me/BotFather → /newbot).
TELEGRAM_BOT_TOKEN=

# Recipient chat ID — the chat where alerts are delivered. Find via
# @userinfobot or by sending /start to your bot and reading the chat_id
# from the bot's updates feed. The daemon silently drops inbound messages
# from any other chat ID (AR20 chat-ID allowlist).
TELEGRAM_CHAT_ID=

# ─────────────────────────────────────────────────────────────────────────
# Hermes Agent (remote service)
# ─────────────────────────────────────────────────────────────────────────
# Hermes runs as a separate service on the operator's host (e.g., a
# Proxmox VM). This daemon connects to that running Hermes instance for
# scheduler + memory + MCP routing (including TinyFish). See NFR-I1 for
# the v0.13.x version pin (applies to the running Hermes service).

HERMES_URL=
HERMES_API_KEY=

# ─────────────────────────────────────────────────────────────────────────
# LLM provider (default: Gemini Flash)
# ─────────────────────────────────────────────────────────────────────────

# Google Gemini API key — get one at https://aistudio.google.com/apikey.
# Used by the default LlmGeminiEvaluator adapter. Swappable per NFR-I3
# (set llm.provider in config.yaml + provide the matching key here).
GEMINI_API_KEY=

# ─────────────────────────────────────────────────────────────────────────
# eBay.es developer credentials
# ─────────────────────────────────────────────────────────────────────────
# Register at https://developer.ebay.com. The OAuth flow + token storage
# runs once via `hardware-hunter login ebay`; tokens are kept in
# data_dir/auth/oauth_tokens.json with mode 0600.

EBAY_APP_ID=
EBAY_CERT_ID=
EBAY_DEV_ID=

# ─────────────────────────────────────────────────────────────────────────
# TinyFish (via Hermes MCP)
# ─────────────────────────────────────────────────────────────────────────
# This daemon never embeds the TinyFish SDK directly (NFR-I2). TinyFish is
# wired into Hermes' MCP server config. If your Hermes deployment already
# holds the TinyFish credentials, you may leave this empty here.

TINYFISH_API_KEY=
